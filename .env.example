# ─────────────────────────────────────────────────────────────────────────────
# Atlas AI — Environment Variables
# Atlas AI — Environment Configuration
#
# HOW TO USE:
#   Frontend: cp .env.example .env.local   → fill in NEXT_PUBLIC_* values
#   Backend:  cp .env.example backend/.env → fill in SUPABASE_* + ALLOWED_ORIGINS
#
# Get Supabase values from: app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# ── API keys (backend reads these from backend/.env) ─────────────────────────

# Serper — Google Places discovery: https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Google Places API (New) — business enrichment: https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# ── Frontend (Next.js .env.local) ────────────────────────────────────────────

# Supabase — public anon key, safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# FastAPI backend URL
# Local dev:  http://localhost:8000
# Production: https://your-service.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Backend (FastAPI backend/.env) ────────────────────────────────────────────

# Supabase — service role key, NEVER expose in the frontend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Comma-separated allowed CORS origins (set your Netlify URL in production)
# Production example: https://yourapp.netlify.app,https://yourapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional — for future LLM-powered quality audit (not required for core search)
# ANTHROPIC_API_KEY=sk-ant-...
